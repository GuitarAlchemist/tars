{
  "Name": "JokeGenerator",
  "Description": "A simple workflow that generates a joke about a topic",
  "Version": "1.0",
  "Inputs": [
    {
      "Name": "topic",
      "Type": "string",
      "Description": "Topic for the joke"
    }
  ],
  "Steps": [
    {
      "Id": "pick_topic",
      "Type": "agent",
      "DependsOn": null,
      "Agent": "CreativeBot",
      "Tool": null,
      "Instruction": "Pick a random, funny object to make a joke about. Return just the object name.",
      "Params": null,
      "Context": null,
      "Outputs": [
        "object"
      ],
      "Tools": null
    },
    {
      "Id": "tell_joke",
      "Type": "agent",
      "DependsOn": [
        {
          "StepId": "pick_topic",
          "Condition": null
        }
      ],
      "Agent": "ComedianBot",
      "Tool": null,
      "Instruction": "Tell a short, puns-filled joke about {{pick_topic.object}}.",
      "Params": null,
      "Context": null,
      "Outputs": [
        "joke"
      ],
      "Tools": null
    }
  ]
}