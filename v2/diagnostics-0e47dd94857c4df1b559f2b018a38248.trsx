put: \u00221\u0022\nprintfn \u0022%s\u0022 (factorial -3)  // Expected output: \u0022Error: Negative input\u0022\n\u0060\u0060\u0060\n\n**Final Solution**\n\nThe F# function to calculate the factorial of a number using recursion is:\n\n\u0060\u0060\u0060fsharp\nlet rec factorial n =\n    match n with\n    | n when n \u003C 0 -\u003E \u0022Error: Negative input\u0022\n    | 0 -\u003E 1\n    | _ -\u003E n * factorial (n - 1)\n\u0060\u0060\u0060\n\nThis function handles edge cases for negative inputs and correctly calculates the factorial for non-negative numbers.\u0022\n     Timestamp = 2025-12-28 9:06:15 AM\n     Metadata = map [] };\n   { Id = 32c6d227-6911-42e7-b7a4-beabfc6832c4\n     CorrelationId = CorrelationId 900f27f4-1ab7-4815-90f5-bc3193b843c2\n     Sender = Agent (AgentId 5093eb53-d973-4aef-b946-7cd20b7267b7)\n     Receiver = Some System\n     Performative = Inform\n     Intent = None\n     Constraints = { MaxTokens = None\n                     MaxComplexity = None\n                     Timeout = None\n                     KnowledgeBoundary = [] }\n     Ontology = None\n     Language = \u0022text\u0022\n     Content =\n      \u0022\u0060\u0060\u0060tool\n{\u0022name\u0022: \u0022write_code\u0022, \u0022arguments\u0022: {\u0022path\u0022: \u0022src/Factorial.fs\u0022, \u0022content\u0022: \u0022let rec factorial n =\\n    match n with\\n    | n when n \u003C 0 -\u003E \\\u0022Error: Negative input\\\u0022\\n    | 0 -\u003E 1\\n    | _ -\u003E n * factorial (n - 1)\u0022}}\n\u0060\u0060\u0060\u0022\n     Timestamp = 2025-12-28 9:06:17 AM\n     Metadata = map [] };\n   { Id = 8c9412e2-6ab4-4466-89ea-0f9be13391fc\n     CorrelationId = CorrelationId 9d7b90e2-9b2c-4925-bcb7-3db32205b39c\n     Sender = System\n     Receiver = Some System\n     Performative = Inform\n     Intent = None\n     Constraints = { MaxTokens = None\n                     MaxComplexity = None\n                     Timeout = None\n                     KnowledgeBoundary = [] }\n     Ontology =