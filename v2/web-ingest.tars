{"name":"web-ingest","version":"0.5","steps":[{"id":"fetch","type":"tool","tool":"web_fetch","params":{"url":"https://example.com"},"outputs":["stdout"]},{"id":"strip","type":"tool","tool":"html_to_text","params":{"html":"{{fetch.stdout}}"},"outputs":["stdout"]},{"id":"summarize","type":"agent","agent":"Assistant","instruction":"You are an expert technical summarizer. Summarize the provided text and extract 3-5 key facts in under 120 words. Do not ask for more info. Text:\n{{strip.stdout}}","outputs":["summary"]}]}
