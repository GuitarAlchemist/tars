# TARS v2 Environment Configuration
# Copy this file to .env and adjust as needed

# PostgreSQL Connection (for Knowledge Ledger)
TARS_POSTGRES_CONNECTION=Host=localhost;Database=tars_memory;Username=postgres;Password=tars_password

# LLM Backend (ollama, llamacpp, openai, docker-model-runner)
TARS_LLM_BACKEND=llamacpp

# llama.cpp server URL (when using llamacpp backend)
TARS_LLAMACPP_URL=http://localhost:8080

# Ollama URL (when using ollama backend)
TARS_OLLAMA_URL=http://localhost:11434

# OpenAI API Key (when using openai backend)
# OPENAI_API_KEY=sk-...

# Default model for LLM operations
TARS_DEFAULT_MODEL=qwen3-8b
