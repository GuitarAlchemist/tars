@prefix ex: <http://example.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

ex:securityCode a ex:VaultCode ;
    ex:part1 "88" ;
    ex:part2 "99" ;
    ex:suffix "X" .

ex:vault ex:hasCode ex:securityCode ;
    ex:location "Sublevel 4" .

ex:instructions ex:order "part1 then part2 then suffix" .
