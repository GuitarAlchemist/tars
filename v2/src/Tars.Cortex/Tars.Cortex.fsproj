  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Tars.Core\Tars.Core.fsproj" />
    <ProjectReference Include="..\Tars.Kernel\Tars.Kernel.fsproj" />
    <ProjectReference Include="..\Tars.Llm\Tars.Llm.fsproj" />
    <ProjectReference Include="..\Tars.Knowledge\Tars.Knowledge.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FSharp.Compiler.Service" Version="43.10.101" />
    <PackageReference Include="FSharp.SystemTextJson" Version="1.4.36" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="9.0.5" />
    <PackageReference Include="Microsoft.SemanticKernel" Version="1.67.1" />
    <PackageReference Update="FSharp.Core" Version="10.0.101" />
