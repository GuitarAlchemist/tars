    <Compile Include="CognitiveBenchmarker.fs" />
    <Compile Include="ContextCompression.fs" />
    <Compile Include="PreLlmPipeline.fs" />
    <Compile Include="EpistemicGovernor.fs" />
    <Compile Include="CapabilityStore.fs" />
    <Compile Include="AstIngestor.fs" />
    <Compile Include="CodeGraphIngestor.fs" />
    <Compile Include="Inference.fs" />
    <Compile Include="OutputGuardAnalyzerLlm.fs" />
    <Compile Include="EntityExtractor.fs" />
    <Compile Include="SemanticWatchdog.fs" />
    <Compile Include="UncertaintyGatedPlanner.fs" />
    <Compile Include="ConsensusCircuitBreaker.fs" />
