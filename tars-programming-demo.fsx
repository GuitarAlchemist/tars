// Test 1: F# Functional Programming Concepts
printfn "🧠 Test 1: F# Functional Programming Learning"
printfn "============================================="

// Higher-order functions and composition
let numbers = [1..20]

let processNumbers nums =
    nums
    |> List.filter (fun x -> x % 2 = 0)
    |> List.map (fun x -> x * x)
    |> List.fold (+) 0

let result1 = processNumbers numbers
printfn "Processed numbers result: %d" result1

// Pattern matching demonstration
let analyzeNumber n =
    match n with
    | x when x < 0 -> "Negative"
    | 0 -> "Zero"
    | x when x % 2 = 0 -> "Even positive"
    | _ -> "Odd positive"

printfn "\nPattern matching examples:"
[1; 0; -5; 8; 15] |> List.iter (fun n -> 
    printfn "%d is %s" n (analyzeNumber n))

// Test 2: Advanced F# Features
printfn "\n🔧 Test 2: Advanced F# Features"
printfn "==============================="

// Record types and computation expressions
type Person = {
    Name: string
    Age: int
    Skills: string list
}

type LearningResult<'T> = 
    | Success of 'T
    | Learning of string * 'T
    | NeedsImprovement of string

// Computation expression for learning
type LearningBuilder() =
    member _.Bind(result, f) =
        match result with
        | Success value -> f value
        | Learning (msg, value) -> 
            printfn "  📚 Learning: %s" msg
            f value
        | NeedsImprovement msg -> 
            printfn "  ⚠️  Needs improvement: %s" msg
            NeedsImprovement msg
    
    member _.Return(value) = Success value
    
    member _.ReturnFrom(result) = result

let learning = LearningBuilder()

// Demonstrate learning computation expression
let learnProgramming person =
    learning {
        let! basicSkills = 
            if person.Skills |> List.contains "F#" then 
                Success person
            else 
                Learning ("Adding F# to skill set", { person with Skills = "F#" :: person.Skills })
        
        let! advancedSkills = 
            if basicSkills.Skills |> List.contains "Pattern Matching" then
                Success basicSkills
            else
                Learning ("Learning pattern matching", { basicSkills with Skills = "Pattern Matching" :: basicSkills.Skills })
        
        return { advancedSkills with Skills = "Functional Programming" :: advancedSkills.Skills }
    }

let tars = { Name = "TARS"; Age = 1; Skills = ["AI"; "Learning"] }
let improvedTars = learnProgramming tars

match improvedTars with
| Success person -> 
    printfn "✅ TARS successfully learned programming!"
    printfn "   Skills: %s" (String.concat ", " person.Skills)
| Learning (msg, person) -> 
    printfn "📚 TARS is learning: %s" msg
    printfn "   Current skills: %s" (String.concat ", " person.Skills)
| NeedsImprovement msg -> 
    printfn "⚠️  TARS needs improvement: %s" msg

// Test 3: Code Generation Capabilities
printfn "\n🎯 Test 3: Code Generation Capabilities"
printfn "======================================="

// Function to generate F# code
let generateFSharpFunction functionName paramName operation =
    sprintf """let %s %s =
    // Generated by TARS
    let result = %s
    printfn "Result of %s(%%A) = %%A" %s result
    result""" functionName paramName operation functionName paramName

// Generate some example functions
let doubleFunction = generateFSharpFunction "double" "x" "x * 2"
let squareFunction = generateFSharpFunction "square" "n" "n * n"
let factorialFunction = generateFSharpFunction "factorial" "n" "let rec fact n acc = if n <= 1 then acc else fact (n - 1) (acc * n) in fact n 1"

printfn "Generated F# Functions:"
printfn "%s" doubleFunction
printfn "%s" squareFunction

// Test 4: Metascript Generation
printfn "\n📜 Test 4: Metascript Generation"
printfn "==============================="

type MetascriptBlock = {
    BlockType: string
    Content: string
    Variables: Map<string, string>
}

type GeneratedMetascript = {
    Name: string
    Description: string
    Blocks: MetascriptBlock list
    CreatedAt: DateTime
}

let generateMetascript name description tasks =
    let describeBlock = {
        BlockType = "DESCRIBE"
        Content = sprintf """name: "%s"
    version: "1.0"
    description: "%s"
    author: "TARS Autonomous Generator"
    date: "%s" """ name description (DateTime.Now.ToString("yyyy-MM-dd"))
        Variables = Map.empty
    }
    
    let configBlock = {
        BlockType = "CONFIG"
        Content = """model: "llama3"
    temperature: 0.5
    max_tokens: 1500
    enable_learning: true"""
        Variables = Map.empty
    }
    
    let taskBlocks = 
        tasks
        |> List.mapi (fun i task ->
            {
                BlockType = "FSHARP"
                Content = sprintf """// Task %d: %s
    printfn "Executing task: %s"
    
    // TARS-generated implementation
    let executeTask() =
        printfn "✅ Task completed successfully"
        "Task %d completed"
    
    executeTask()""" (i + 1) task task (i + 1)
                Variables = Map.empty
            })
    
    {
        Name = name
        Description = description
        Blocks = describeBlock :: configBlock :: taskBlocks
        CreatedAt = DateTime.Now
    }

// Generate a sample metascript
let sampleTasks = [
    "Analyze code patterns"
    "Generate optimized functions"
    "Learn from execution results"
    "Improve code quality"
]

let generatedScript = generateMetascript "TARS Learning Demo" "Autonomous programming learning demonstration" sampleTasks

printfn "Generated Metascript: %s" generatedScript.Name
printfn "Description: %s" generatedScript.Description
printfn "Blocks: %d" generatedScript.Blocks.Length

// Save the generated metascript
let metascriptContent = 
    generatedScript.Blocks
    |> List.map (fun block ->
        sprintf "%s {\n    %s\n}" block.BlockType block.Content)
    |> String.concat "\n\n"

let fileName = "generated-tars-learning-demo.tars"
File.WriteAllText(fileName, metascriptContent)
printfn "✅ Metascript saved to: %s" fileName

