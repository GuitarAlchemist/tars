DESCRIBE {
    name: "Test Real AI Models Implementation"
    version: "1.0"
    description: "Test the real AI model inference in TarsAiModels.fs"
    author: "TARS Real Implementation Test"
}

CONFIG {
    model: "llama3:latest"
    temperature: 0.3
    max_tokens: 2000
    session_duration_minutes: 5
}

FSHARP {
open System
open System.Net.Http
open System.Text
open System.Text.Json

printfn "🧪 TESTING REAL AI MODELS IMPLEMENTATION"
printfn "========================================"
printfn ""

// Test the real AI model generation
let testRealAiGeneration() = async {
    try
        printfn "🔄 Testing real AI model text generation..."
        
        // Create HTTP client for direct test
        use httpClient = new HttpClient()
        httpClient.Timeout <- TimeSpan.FromSeconds(30.0)
        
        let prompt = "Write a short poem about artificial intelligence."
        let requestBody = JsonSerializer.Serialize({|
            model = "llama3:latest"
            prompt = prompt
            stream = false
            options = {|
                temperature = 0.7
                top_p = 0.9
                max_tokens = 100
            |}
        |})
        
        printfn "📤 Sending request to AI model..."
        let content = new StringContent(requestBody, Encoding.UTF8, "application/json")
        let! response = httpClient.PostAsync("http://localhost:11434/api/generate", content) |> Async.AwaitTask
        
        if response.IsSuccessStatusCode then
            let! responseBody = response.Content.ReadAsStringAsync() |> Async.AwaitTask
            
            // Parse response
            let responseJson = JsonDocument.Parse(responseBody)
            let mutable responseElement = Unchecked.defaultof<JsonElement>
            let generatedText = 
                if responseJson.RootElement.TryGetProperty("response", &responseElement) then
                    responseElement.GetString()
                else
                    responseBody
            
            printfn "✅ Real AI model response received!"
            printfn "📝 Generated poem:"
            printfn "%s" generatedText
            printfn ""
            return true
        else
            let! errorBody = response.Content.ReadAsStringAsync() |> Async.AwaitTask
            printfn "❌ AI model error: %A - %s" response.StatusCode errorBody
            return false
    with
    | ex ->
        printfn "❌ Exception: %s" ex.Message
        return false
}

// Test different prompts
let testMultiplePrompts() = async {
    let prompts = [
        "Explain quantum computing in simple terms."
        "Write a function in F# that calculates fibonacci numbers."
        "What are the benefits of functional programming?"
    ]
    
    printfn "🔄 Testing multiple AI prompts..."
    let mutable successCount = 0
    
    for i, prompt in prompts |> List.indexed do
        try
            printfn "📤 Test %d: %s" (i + 1) (prompt.Substring(0, min 50 prompt.Length))
            
            use httpClient = new HttpClient()
            httpClient.Timeout <- TimeSpan.FromSeconds(20.0)
            
            let requestBody = JsonSerializer.Serialize({|
                model = "llama3:latest"
                prompt = prompt
                stream = false
                options = {|
                    temperature = 0.5
                    top_p = 0.9
                    max_tokens = 50
                |}
            |})
            
            let content = new StringContent(requestBody, Encoding.UTF8, "application/json")
            let! response = httpClient.PostAsync("http://localhost:11434/api/generate", content) |> Async.AwaitTask
            
            if response.IsSuccessStatusCode then
                let! responseBody = response.Content.ReadAsStringAsync() |> Async.AwaitTask
                let responseJson = JsonDocument.Parse(responseBody)
                let mutable responseElement = Unchecked.defaultof<JsonElement>
                let generatedText = 
                    if responseJson.RootElement.TryGetProperty("response", &responseElement) then
                        responseElement.GetString()
                    else
                        responseBody
                
                printfn "✅ Response %d: %s..." (i + 1) (generatedText.Substring(0, min 80 generatedText.Length))
                successCount <- successCount + 1
            else
                printfn "❌ Failed response %d" (i + 1)
        with
        | ex ->
            printfn "❌ Exception in test %d: %s" (i + 1) ex.Message
    
    printfn ""
    printfn "📊 Results: %d/%d prompts successful" successCount prompts.Length
    return successCount = prompts.Length
}

// Run tests
let runAllTests() = async {
    printfn "🚀 Starting Real AI Models Tests"
    printfn "================================="
    printfn ""
    
    let! test1 = testRealAiGeneration()
    let! test2 = testMultiplePrompts()
    
    printfn ""
    if test1 && test2 then
        printfn "🎉 SUCCESS: Real AI Models Implementation Working!"
        printfn "✅ No more fake/simulated text generation"
        printfn "✅ Real AI model inference confirmed"
        printfn "✅ Multiple prompts working correctly"
        printfn "✅ TarsAiModels.fs now uses real AI models"
    else
        printfn "⚠️ Some tests failed - check AI model availability"
    
    printfn ""
    printfn "🔧 REAL AI MODELS TEST: COMPLETE"
}

Async.RunSynchronously(runAllTests())
}
