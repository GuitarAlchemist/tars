# TARS MCP Server Environment Configuration
# Copy this file to .env and fill in your actual values

# GitHub Integration
GITHUB_TOKEN=your_github_personal_access_token_here
# Get from: https://github.com/settings/tokens
# Scopes needed: repo, read:user, read:org

# GitLab Integration
GITLAB_TOKEN=your_gitlab_personal_access_token_here
# Get from: https://gitlab.com/-/profile/personal_access_tokens
# Scopes needed: api, read_user, read_repository

# Database Connections
POSTGRES_URL=postgresql://username:password@localhost:5432/database_name
# Example: postgresql://tars:password@localhost:5432/tars_db

# Search APIs
BRAVE_API_KEY=your_brave_search_api_key_here
# Get from: https://api.search.brave.com/app/keys

# Slack Integration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
# Get from: https://api.slack.com/apps -> Your App -> OAuth & Permissions

# OpenAI (if using OpenAI-based MCP servers)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (if using Claude-based MCP servers)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google (if using Google-based MCP servers)
GOOGLE_API_KEY=your_google_api_key_here

# TARS Specific Configuration
TARS_LOG_LEVEL=INFO
TARS_MCP_PORT=8999
TARS_DATA_DIR=./data
TARS_CACHE_DIR=./cache

# Development Settings
NODE_ENV=development
DEBUG=mcp:*
