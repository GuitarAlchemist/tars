  </PropertyGroup>

  <ItemGroup>
    <Compile Include="ProgrammingLearningValidation.fs" />
    <Compile Include="MetascriptEvolutionValidation.fs" />
    <Compile Include="AutonomousImprovementValidation.fs" />
    <Compile Include="ProductionIntegrationValidation.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>





</Project>
