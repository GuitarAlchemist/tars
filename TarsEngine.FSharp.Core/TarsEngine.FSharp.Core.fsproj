    <Compile Include="GameTheoryWebGPUShaders.fs" />
    <Compile Include="GameTheoryInterstellarEffects.fs" />
    <Compile Include="GameTheory3DIntegrationService.fs" />
    
    <!-- Working Core Modules -->
