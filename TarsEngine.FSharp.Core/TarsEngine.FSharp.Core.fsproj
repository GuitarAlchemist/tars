    <Compile Include="TarsAutoReflection.fs" />
    <Compile Include="TarsAdvancedFlux.fs" />
    <Compile Include="TarsCliIntegration.fs" />
    <Compile Include="TarsBeliefDriftVisualization.fs" />
    <Compile Include="TarsExtendedPrimePatterns.fs" />
    <Compile Include="TarsMetaCognitiveLoops.fs" />
    <Compile Include="TarsEnhancedEvolution.fs" />
    <Compile Include="TarsAutonomousCodeAnalysis.fs" />
    <Compile Include="TarsAutonomousCodeModification.fs" />
    <Compile Include="TarsPerformanceDrivenEvolution.fs" />
    <Compile Include="TestTarsEvolution.fs" />
    <Compile Include="AutonomousEvolutionRunner.fs" />
