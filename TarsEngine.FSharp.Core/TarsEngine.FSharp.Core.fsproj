    <Compile Include="Metascript\MetascriptGrammarRegistry.fs" />
    <Compile Include="Mcp\McpRegistry.fs" />
    <Compile Include="Mcp\McpRequest.fs" />
    <Compile Include="Mcp\McpClient.fs" />
    <Compile Include="Specs\SpecKitIntegration.fs" />
    <Compile Include="Services\CrossAgentValidation.fs" />
    <Compile Include="Services\ReasoningTrace.fs" />
    <Compile Include="Services\MetascriptClosureIntegrationService.fs" />

    <!-- TARS Auto-Improvement System -->
    <Compile Include="TarsProjectDiscovery.fs" />
    <Compile Include="TarsPerformanceMeasurement.fs" />
    <Compile Include="TarsSafeFileOperations.fs" />
    <Compile Include="TarsEvolutionEngine.fs" />
