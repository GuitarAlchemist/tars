<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <WarningsAsErrors />
    <WarningsNotAsErrors>FS0988</WarningsNotAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <!-- Core Types -->
    <Compile Include="RevolutionaryTypes.fs" />
    
    <!-- Modern Game Theory Modules -->
    <Compile Include="ModernGameTheory.fs" />
    <Compile Include="Tier10MetaLearning.fs" />
    <Compile Include="Tier11SelfAwareness.fs" />
    <!-- Re-enabled after fixing compilation errors -->
    <Compile Include="AutonomousKnowledgeBridge.fs" />
    <Compile Include="AutonomousCompetencyValidation.fs" />
    <Compile Include="FeedbackTracker.fs" />
    <Compile Include="GameTheoryFeedbackCLI.fs" />

    <!-- Elmish UI Integration -->
    <Compile Include="GameTheoryElmishModels.fs" />
    <Compile Include="GameTheoryElmishViews.fs" />
    <Compile Include="GameTheoryElmishServices.fs" />
    <Compile Include="GameTheoryElmishApp.fs" />

    <!-- Three.js + WebGPU 3D Integration -->
    <Compile Include="GameTheoryThreeJsIntegration.fs" />
    <Compile Include="GameTheoryWebGPUShaders.fs" />
    <Compile Include="GameTheoryInterstellarEffects.fs" />
    <Compile Include="GameTheory3DIntegrationService.fs" />
    
    <!-- Working Core Modules -->
    <Compile Include="AutonomousEvolution.fs" />
    <Compile Include="BSPReasoningEngine.fs" />
    <Compile Include="ComprehensiveTypes.fs" />
    <Compile Include="TempTypeFixes.fs" />

    <!-- TARS Auto-Improvement System -->
    <Compile Include="TarsProjectDiscovery.fs" />
    <Compile Include="TarsPerformanceMeasurement.fs" />
    <Compile Include="TarsSafeFileOperations.fs" />
    <Compile Include="TarsEvolutionEngine.fs" />
    <Compile Include="TarsPrimePattern.fs" />
    <Compile Include="TarsPrimeCuda.fs" />
    <Compile Include="TarsHurwitzQuaternions.fs" />
    <Compile Include="TarsHurwitzQuaternionsTests.fs" />
    <Compile Include="TarsRsxDiff.fs" />
    <Compile Include="TarsRsxGraph.fs" />
    <Compile Include="TarsSedenionPartitioner.fs" />
    <Compile Include="TarsAutoReflection.fs" />
    <Compile Include="TarsAdvancedFlux.fs" />
    <Compile Include="TarsCliIntegration.fs" />
    <Compile Include="TarsBeliefDriftVisualization.fs" />
    <Compile Include="TarsExtendedPrimePatterns.fs" />
    <Compile Include="TarsMetaCognitiveLoops.fs" />
    <Compile Include="TarsEnhancedEvolution.fs" />
    <Compile Include="TarsAutonomousCodeAnalysis.fs" />
    <Compile Include="TarsAutonomousCodeModification.fs" />
    <Compile Include="TarsPerformanceDrivenEvolution.fs" />
    <Compile Include="TestTarsEvolution.fs" />
    <Compile Include="AutonomousEvolutionRunner.fs" />
    <Compile Include="RealEvolutionRunner.fs" />
    <Compile Include="JanusResearchImprovement.fs" />
    <Compile Include="FullJanusResearchRunner.fs" />
    <Compile Include="TarsOllamaReplacement.fs" />
    <Compile Include="TarsInferenceValidation.fs" />

    <Compile Include="TarsCustomTransformer.fs" />
    <Compile Include="TarsNonEuclideanVectorStore.fs" />
    <Compile Include="AllTarsFeaturesTesting.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging" Version="9.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="9.0.0" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="9.0.0" />
    <PackageReference Include="System.Text.Json" Version="9.0.0" />
  </ItemGroup>

