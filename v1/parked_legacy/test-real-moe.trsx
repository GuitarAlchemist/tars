DESCRIBE {
    name: "Test Real MoE System"
    version: "1.0"
    description: "Test the real Mixture of Experts system implementation"
    author: "TARS Real Implementation Test"
}

CONFIG {
    model: "llama3:latest"
    temperature: 0.3
    max_tokens: 2000
    session_duration_minutes: 5
}

FSHARP {
open System
open System.Net.Http
open System.Text
open System.Text.Json

printfn "🧪 TESTING REAL MOE SYSTEM IMPLEMENTATION"
printfn "========================================"
printfn ""

// Test the MoE system by calling Ollama directly with different expert prompts
let testMoEExpertCall(expertName: string, systemPrompt: string, query: string) = async {
    try
        printfn "🔄 Testing %s expert..." expertName
        
        use httpClient = new HttpClient()
        httpClient.Timeout <- TimeSpan.FromSeconds(30.0)
        
        // Test with OpenAI-compatible endpoint (what MoE uses)
        let payload = {|
            model = "llama3"
            messages = [|
                {| role = "system"; content = systemPrompt |}
                {| role = "user"; content = query |}
            |]
            temperature = 0.7
            max_tokens = 100
            top_p = 0.9
            stream = false
        |}
        
        let jsonContent = JsonSerializer.Serialize(payload)
        let content = new StringContent(jsonContent, Encoding.UTF8, "application/json")
        
        printfn "📤 Sending to OpenAI-compatible endpoint..."
        let! response = httpClient.PostAsync("http://localhost:11434/v1/chat/completions", content) |> Async.AwaitTask
        
        if response.IsSuccessStatusCode then
            let! responseContent = response.Content.ReadAsStringAsync() |> Async.AwaitTask
            let responseData = JsonSerializer.Deserialize<JsonElement>(responseContent)
            
            let content =
                responseData.GetProperty("choices").[0]
                    .GetProperty("message")
                    .GetProperty("content")
                    .GetString()
            
            printfn "✅ %s Expert Response:" expertName
            printfn "📝 %s" (content.Substring(0, min 150 content.Length))
            if content.Length > 150 then printfn "..."
            printfn ""
            return true
        else
            let! errorContent = response.Content.ReadAsStringAsync() |> Async.AwaitTask
            printfn "❌ %s Expert Error: %A - %s" expertName response.StatusCode errorContent
            return false
    with
    | ex ->
        printfn "❌ %s Expert Exception: %s" expertName ex.Message
        return false
}

// Test different expert types
let testMultipleExperts() = async {
    let experts = [
        ("Code Generation", "You are a code generation expert. Write clean, efficient code with proper documentation.", "Write a simple F# function to reverse a string")
        ("Code Analysis", "You are a code analysis expert. Analyze code for quality, performance, and best practices.", "Analyze this code: let add x y = x + y")
        ("Architecture", "You are a software architecture expert. Design scalable, maintainable systems.", "Design a microservices architecture for an e-commerce platform")
        ("Testing", "You are a testing expert. Create comprehensive test strategies and test cases.", "Create test cases for a user authentication system")
    ]
    
    printfn "🚀 Testing Multiple MoE Experts"
    printfn "==============================="
    printfn ""
    
    let mutable successCount = 0
    
    for (expertName, systemPrompt, query) in experts do
        let! success = testMoEExpertCall(expertName, systemPrompt, query)
        if success then
            successCount <- successCount + 1
    
    printfn "📊 MoE Expert Results: %d/%d experts successful" successCount experts.Length
    return successCount = experts.Length
}

// Test fallback to native Ollama endpoint if OpenAI endpoint fails
let testNativeOllamaFallback() = async {
    try
        printfn "🔄 Testing native Ollama endpoint fallback..."
        
        use httpClient = new HttpClient()
        httpClient.Timeout <- TimeSpan.FromSeconds(20.0)
        
        let requestBody = JsonSerializer.Serialize({|
            model = "llama3"
            prompt = "You are a helpful AI assistant. Explain what a Mixture of Experts system is in simple terms."
            stream = false
            options = {|
                temperature = 0.5
                max_tokens = 80
            |}
        |})
        
        let content = new StringContent(requestBody, Encoding.UTF8, "application/json")
        let! response = httpClient.PostAsync("http://localhost:11434/api/generate", content) |> Async.AwaitTask
        
        if response.IsSuccessStatusCode then
            let! responseBody = response.Content.ReadAsStringAsync() |> Async.AwaitTask
            let responseJson = JsonDocument.Parse(responseBody)
            let mutable responseElement = Unchecked.defaultof<JsonElement>
            let generatedText = 
                if responseJson.RootElement.TryGetProperty("response", &responseElement) then
                    responseElement.GetString()
                else
                    responseBody
            
            printfn "✅ Native Ollama Fallback Working!"
            printfn "📝 Response: %s" (generatedText.Substring(0, min 120 generatedText.Length))
            if generatedText.Length > 120 then printfn "..."
            printfn ""
            return true
        else
            printfn "❌ Native Ollama fallback failed"
            return false
    with
    | ex ->
        printfn "❌ Native Ollama fallback exception: %s" ex.Message
        return false
}

// Run all tests
let runAllTests() = async {
    printfn "🚀 Starting Real MoE System Tests"
    printfn "=================================="
    printfn ""
    
    let! test1 = testMultipleExperts()
    let! test2 = testNativeOllamaFallback()
    
    printfn ""
    if test1 && test2 then
        printfn "🎉 SUCCESS: Real MoE System Implementation Working!"
        printfn "✅ Multiple experts using real AI models"
        printfn "✅ OpenAI-compatible endpoint working"
        printfn "✅ Native Ollama fallback available"
        printfn "✅ No more fake/simulated expert responses"
        printfn "✅ MoE system connected to real models"
    else
        printfn "⚠️ Some MoE tests failed - check model availability"
        if not test1 then printfn "  - Expert routing tests failed"
        if not test2 then printfn "  - Native Ollama fallback failed"
    
    printfn ""
    printfn "🔧 REAL MOE SYSTEM TEST: COMPLETE"
}

Async.RunSynchronously(runAllTests())
}
