version "2025.08.29"

// TARS Context Engineering Configuration
// This demonstrates the new context engineering capabilities

context_policy {
    step_token_budget = 12000
    
    compression {
        enabled = true
        strategy = "extractive-v1"
        targets = ["low_salience_notes", "long_logs", "verbose_traces"]
        max_ratio = 0.55
        quality_threshold = 0.85
    }
    
    retrieval {
        router = "intent_router_v1"
        profiles = [
            {
                intent = "plan"
                retrievers = ["bm25+vec", "recent_boost", "belief_graph"]
                chunk = "semantic-para"
                max_spans = 20
                salience_threshold = 0.3
            }
            {
                intent = "codegen"
                retrievers = ["code_ast+vec", "symbol_xref", "pattern_match"]
                chunk = "code-window"
                max_spans = 15
                salience_threshold = 0.4
            }
            {
                intent = "eval"
                retrievers = ["trace-index", "test_results", "performance_metrics"]
                chunk = "short-spans"
                max_spans = 10
                salience_threshold = 0.5
            }
            {
                intent = "reasoning"
                retrievers = ["belief_graph", "contradiction_index", "inference_chains"]
                chunk = "reasoning-blocks"
                max_spans = 25
                salience_threshold = 0.2
            }
            {
                intent = "metascript_execution"
                retrievers = ["metascript_patterns", "execution_history", "variable_context"]
                chunk = "metascript-segments"
                max_spans = 18
                salience_threshold = 0.35
            }
            {
                intent = "autonomous_improvement"
                retrievers = ["self_analysis", "improvement_history", "performance_trends"]
                chunk = "improvement-blocks"
                max_spans = 22
                salience_threshold = 0.25
            }
        ]
    }
    
    fewshot {
        max_examples = 6
        policy = "salience-topk"
        intent_specific = true
        auto_retire_stale = true
        performance_weighted = true
    }
    
    memory {
        ephemeral_max_spans = 100
        working_set_max_spans = 500
        consolidation_frequency = "daily"
        salience_decay_rate = 0.95
        promotion_threshold = 0.6
    }
    
    security {
        sanitization_enabled = true
        injection_detection = true
        tool_allowlist = ["fs.read", "git.diff", "run.tests", "cuda.benchmark", "metascript.execute"]
        content_filtering = ["system_prompts", "credentials", "private_keys"]
    }
}

// Example compression log from a TARS execution
compression_log {
    timestamp = "2025-08-29T10:30:00Z"
    ratio = 0.47
    quality_estimate = 0.92
    tokens_saved = 3200
