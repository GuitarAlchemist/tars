<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="AssemblyInfo.fs" />
    <!-- Core Types and Infrastructure -->
    <Compile Include="ImprovementTypes.fs" />
    <Compile Include="LearningDatabase.fs" />

    <!-- Pattern Recognition and Analysis -->
    <Compile Include="PatternRecognition.fs" />
    <Compile Include="ImprovementSuggestions.fs" />

    <!-- Code Transformation and Execution -->
    <Compile Include="CodeTransforms.fs" />
    <Compile Include="ExecutionHarness.fs" />
    <Compile Include="Services\ModelRecommendationService.fs" />
    <Compile Include="ModelSelection.fs" />

    <!-- Knowledge Extraction Models (must come before Ollama modules that use them) -->
    <Compile Include="KnowledgeExtractionModels.fs" />
    <Compile Include="ExplorationFileProcessor.fs" />

    <!-- Agent Coordination and Feedback (must come before MetaReasoningCritic) -->
    <Compile Include="CrossAgentFeedback.fs" />
    <Compile Include="ValidatorCoordination.fs" />
    <Compile Include="PersistentAdaptiveMemory.fs" />

    <!-- Meta Reasoning (must come before OllamaCodeAnalyzer) -->
    <Compile Include="MetaReasoningCritic.fs" />

    <!-- Ollama Integration -->
    <Compile Include="OllamaModels.fs" />
    <Compile Include="OllamaCodeAnalyzer.fs" />
    <Compile Include="OllamaKnowledgeExtractor.fs" />
    <Compile Include="OllamaImprovementApplier.fs" />
    <Compile Include="OpenSearchIntegration.fs" />

    <!-- Knowledge Extraction -->
    <Compile Include="KnowledgeExtractor.fs" />

    <!-- Workflow Management -->
    <Compile Include="WorkflowState.fs" />
    <Compile Include="WorkflowScheduler.fs" />
    <Compile Include="WorkflowEngine.fs" />
    <Compile Include="RetroactionLoop.fs" />

    <!-- Workflow Steps -->
    <Compile Include="KnowledgeExtractionStep.fs" />
    <Compile Include="CodeAnalysisStep.fs" />
    <Compile Include="ExecutionValidationStep.fs" />
    <Compile Include="ImprovementApplicationStep.fs" />
    <Compile Include="FeedbackCollectionStep.fs" />
    <Compile Include="ReportingStep.fs" />

    <!-- Autonomous Capabilities (must come before AdaptivePolicy) -->
    <Compile Include="AutonomousSpecHarness.fs" />
    <Compile Include="SpecKitWorkspace.fs" />
    <Compile Include="TeamConfiguration.fs" />
    <Compile Include="ProductBacklogDecomposer.fs" />
    <Compile Include="SpecKitGoalPlanner.fs" />
    <Compile Include="GovernanceLedger.fs" />
    <Compile Include="RoadmapMaintenance.fs" />
    <Compile Include="AuggieIntegration.fs" />
    <Compile Include="AutonomousNextStepPlanner.fs" />
    <Compile Include="TeamOrchestrator.fs" />
    <Compile Include="AutonomousImprovementService.fs" />

    <!-- Agent Policy and Reasoning -->
    <Compile Include="AgentPolicyTuning.fs" />
    <Compile Include="AdaptivePolicy.fs" />
    <Compile Include="ReasoningFeedback.fs" />

    <!-- Main Service -->
    <Compile Include="SelfImprovementService.fs" />
    <Compile Include="Tier2Runner.fs" />

    <!-- Legacy Library (for backward compatibility) -->
    <Compile Include="Library.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FSharp.Data" Version="6.6.0" />
    <PackageReference Include="FSharp.SystemTextJson" Version="1.2.42" />
    <PackageReference Include="Microsoft.Extensions.Logging" Version="9.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="9.0.0" />
    <PackageReference Include="System.Text.Json" Version="9.0.5" />
    <PackageReference Include="YamlDotNet" Version="15.1.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\TarsEngine.FSharp.Core\TarsEngine.FSharp.Core.fsproj" />
    <ProjectReference Include="..\TarsEngine.FSharp.Metascript\TarsEngine.FSharp.Metascript.fsproj" />
    <ProjectReference Include="..\Tars.Engine.VectorStore\Tars.Engine.VectorStore.fsproj" />
  </ItemGroup>
</Project>
