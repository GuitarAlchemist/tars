DESCRIBE {
    name: "Test Real Qwen Implementation"
    version: "1.0"
    description: "Test the real Qwen model implementation via Ollama API"
    author: "TARS Real Implementation Test"
}

CONFIG {
    model: "qwen3:latest"
    temperature: 0.3
    max_tokens: 2000
    session_duration_minutes: 5
}

FSHARP {
open System
open System.Net.Http
open System.Text
open System.Text.Json

printfn "🧪 TESTING REAL QWEN IMPLEMENTATION"
printfn "==================================="
printfn ""

// Test if Ollama is running
let testOllamaConnection() = async {
    try
        use httpClient = new HttpClient()
        httpClient.Timeout <- TimeSpan.FromSeconds(10.0)
        
        let! response = httpClient.GetAsync("http://localhost:11434/api/tags") |> Async.AwaitTask
        
        if response.IsSuccessStatusCode then
            let! content = response.Content.ReadAsStringAsync() |> Async.AwaitTask
            printfn "✅ Ollama is running and accessible"
            printfn "📋 Available models response: %s" (content.Substring(0, min 100 content.Length))
            return true
        else
            printfn "❌ Ollama responded with status: %A" response.StatusCode
            return false
    with
    | ex ->
        printfn "❌ Failed to connect to Ollama: %s" ex.Message
        return false
}

// Test real Qwen model call
let testRealQwenCall() = async {
    try
        use httpClient = new HttpClient()
        httpClient.Timeout <- TimeSpan.FromSeconds(30.0)
        
        let requestBody = JsonSerializer.Serialize({|
            model = "llama3:latest"
            prompt = "What is 2+2? Please think step by step."
            stream = false
            options = {|
                temperature = 0.3
                top_p = 0.9
                max_tokens = 50
            |}
        |})
        
        printfn "🔄 Sending request to Qwen model..."
        let content = new StringContent(requestBody, Encoding.UTF8, "application/json")
        let! response = httpClient.PostAsync("http://localhost:11434/api/generate", content) |> Async.AwaitTask
        
        if response.IsSuccessStatusCode then
            let! responseBody = response.Content.ReadAsStringAsync() |> Async.AwaitTask
            
            // Parse response
            let responseJson = JsonDocument.Parse(responseBody)
            let mutable responseElement = Unchecked.defaultof<JsonElement>
            let responseText =
                if responseJson.RootElement.TryGetProperty("response", &responseElement) then
                    responseElement.GetString()
                else
                    responseBody
            
            printfn "✅ Real Qwen response received!"
            printfn "📝 Response: %s" responseText
            return true
        else
            let! errorBody = response.Content.ReadAsStringAsync() |> Async.AwaitTask
            printfn "❌ Qwen API error: %A - %s" response.StatusCode errorBody
            return false
    with
    | ex ->
        printfn "❌ Exception calling Qwen: %s" ex.Message
        return false
}

// Run tests
let runTests() = async {
    printfn "🔍 Step 1: Testing Ollama connection..."
    let! ollamaConnected = testOllamaConnection()
    
    if ollamaConnected then
        printfn ""
        printfn "🔍 Step 2: Testing real Qwen model call..."
        let! qwenWorked = testRealQwenCall()
        
        printfn ""
        if qwenWorked then
            printfn "🎉 SUCCESS: Real Qwen implementation is working!"
            printfn "✅ No more fake/simulated responses"
            printfn "✅ Real AI model inference confirmed"
        else
            printfn "⚠️ Qwen model call failed - check model availability"
    else
        printfn "⚠️ Cannot test Qwen - Ollama not accessible"
        printfn "💡 Make sure Ollama is running: ollama serve"
}

Async.RunSynchronously(runTests())

printfn ""
printfn "🔧 REAL QWEN IMPLEMENTATION TEST: COMPLETE"
}
